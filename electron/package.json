{
  "name": "purveyols-desktop",
  "version": "1.0.0",
  "description": "PURVEYOLS Construction Management System – Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.purveyols.desktop",
    "productName": "PURVEYOLS",
    "directories": {
      "buildResources": "assets",
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "../frontend/dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PURVEYOLS"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2"
  }
}
